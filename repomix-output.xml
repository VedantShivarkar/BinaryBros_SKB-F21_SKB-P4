      <div className="dashboard-grid">
        <div className="glass-panel full-width">
          <h2>Assurance-Ready Analytics (Level 1)</h2>
          <Level1Dashboard />
        </div>
        
        <div className="glass-panel full-width">
          <h2>Farmer Geolocation & AWD Heatmap (Level 2)</h2>
          <Level2Map />
        </div>
      </div>
    </div>
  );
}

export default App;
