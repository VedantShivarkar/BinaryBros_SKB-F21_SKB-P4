<file path="frontend/src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap');
@import url('https://unpkg.com/leaflet@1.9.4/dist/leaflet.css');

:root {
  --bg-dark: #121212;
  --bg-card: rgba(28, 28, 30, 0.7);
  --text-primary: #ffffff;
  --text-secondary: #a0a0a5;
  --accent-green: #00ff88;
  --accent-blue: #00d4ff;
  --accent-warning: #ffb800;
  --border-color: rgba(255, 255, 255, 0.08);
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Inter', sans-serif;
  background-color: var(--bg-dark);
  color: var(--text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

h1, h2, h3 {
  font-weight: 600;
  letter-spacing: -0.02em;
}

.glass-panel {
  background: var(--bg-card);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--border-color);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.glass-panel:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 40px 0 rgba(0, 255, 136, 0.1);
  border-color: rgba(0, 255, 136, 0.3);
}

.glow-text-green {
  color: var(--accent-green);
  text-shadow: 0 0 12px rgba(0, 255, 136, 0.4);
}

.glow-text-blue {
  color: var(--accent-blue);
  text-shadow: 0 0 12px rgba(0, 212, 255, 0.4);
}

.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  padding: 32px;
  max-width: 1400px;
  margin: 0 auto;
}

.full-width {
  grid-column: 1 / -1;
}

.header {
  text-align: center;
  padding: 40px 20px 20px;
}

.header h1 {
  font-size: 2.5rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent-green), var(--accent-blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12px;
}

.metrics-row {
  display: flex;
  gap: 24px;
  margin-bottom: 24px;
}

.metric-card {
  flex: 1;
  text-align: center;
  padding: 24px;
  background: rgba(255,255,255,0.02);
  border-radius: 12px;
  border: 1px solid var(--border-color);
}

.metric-value {
  font-size: 3rem;
  font-weight: 800;
  margin: 12px 0;
}

.metric-label {
  color: var(--text-secondary);
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 16px;
}

.data-table th, .data-table td {
  padding: 16px;
  text-align: left;
  border-bottom: 1px solid var(--border-color);
}

.data-table th {
  color: var(--text-secondary);
  font-weight: 600;
  font-size: 0.85rem;
  text-transform: uppercase;
}

.data-table tr:hover {
  background-color: rgba(255, 255, 255, 0.02);
}

.badge {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 0.8rem;
  font-weight: 600;
}

.badge.wet { background: rgba(0, 212, 255, 0.15); color: var(--accent-blue); border: 1px solid rgba(0, 212, 255, 0.3); }
.badge.dry { background: rgba(255, 184, 0, 0.15); color: var(--accent-warning); border: 1px solid rgba(255, 184, 0, 0.3); }

/* Leaflet override */
.leaflet-container {
  border-radius: 12px;
  width: 100%;
  height: 400px;
  z-index: 10;
  border: 1px solid var(--border-color);
}
</file>

