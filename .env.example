# Amrit Vaayu dMRV - Environment Variables Example
# Copy this file to '.env' and substitute your actual keys. DO NOT commit '.env'.

# --- Database Configurations ---
# Obtain from your Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# --- AI & Reasoning Engine ---
# Obtain your lightning-fast inference API key from https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- Messaging Webhook ---
# Generally pulled by the Twilio application automatically, 
# but provided here if you add local Auth validation to the FastAPI route in the future.
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
